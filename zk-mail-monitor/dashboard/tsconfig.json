{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "es2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@reputation-engine/*": ["../reputation-engine/src/*"],
      "@analyzer/*": ["../analyzer/src/*"],
      "@mailchain-service/*": ["../mailchain-service/src/*"],
      "@client/*": ["../client/src/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@components/*": ["./src/components/*"]
    }
  },
   "include": ["src", "../mailchain-service/src", "../analyzer/src"]

}
